class Solution {
    public int tribonacci(int n) {
        int i=0;
        int j=1;
        int k=1;
        if(n==0) return i;
        if(n==1) return j;
        if(n==2) return k;
        //if(n==3) return k;
        int r=0;
        for(int s=3;s<=n;s++){
            r=i+j+k;
            i=j;
            j=k;
            k=r;
        }
        return r;
    }
}