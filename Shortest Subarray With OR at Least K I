class Solution {
    public int minimumSubarrayLength(int[] nums, int k) {
        int min=Integer.MAX_VALUE;
        for(int i=0;i<nums.length;i++){
            int ans=0;
            for(int j=i;j<nums.length;j++){
                ans|=nums[j];
                if(ans>=k){
                    min=Math.min(min,j-i+1);
                }
            }
        }
        return min==Integer.MAX_VALUE?-1:min;
    }
}